      ],
      "id": "aa0164d1-25b8-4435-a513-ac4329e9adfd",
      "name": "Structure Candidate Data"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Evaluate the following candidate against the job requirements.\n\nJob:\n\n{{ JSON.stringify($('Get JOB').item.json, null, 2) }}\n\nCandidate:\n{{ JSON.stringify( $('Structure Candidate Data').item.json.output)}}\n\n\nEvaluate the candidate and return the structured result.",
        "hasOutputParser": true,
        "messages": {
          "messageValues": [
            {
              "message": "You are an experienced technical recruiter and hiring manager.\n\nYour task is to evaluate a candidate against a job description.\n\nRules:\n\n- Evaluate only using the provided information.\n- Never invent skills or experience.\n- If information is missing, treat it as unknown.\n- Compare the candidate only against the supplied job requirements.\n- Be objective and consistent.\n- Return only the requested structured output."
            }
          ]
        },
        "batching": {}
      },
