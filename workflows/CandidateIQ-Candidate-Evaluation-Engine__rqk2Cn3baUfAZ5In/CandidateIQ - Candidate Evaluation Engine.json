      "parameters": {
        "text": "={{ $json.text }}",
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"personal_information\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"first_name\": {\n          \"type\": [\"string\", \"null\"]\n        },\n        \"last_name\": {\n          \"type\": [\"string\", \"null\"]\n        },\n        \"email\": {\n          \"type\": [\"string\", \"null\"]\n        },\n        \"phone\": {\n          \"type\": [\"string\", \"null\"]\n        },\n        \"location\": {\n          \"type\": [\"string\", \"null\"]\n        },\n        \"linkedin_url\": {\n          \"type\": [\"string\", \"null\"]\n        },\n        \"github_url\": {\n          \"type\": [\"string\", \"null\"]\n        },\n        \"portfolio_url\": {\n          \"type\": [\"string\", \"null\"]\n        }\n      }\n    },\n    \"professional_summary\": {\n      \"type\": [\"string\", \"null\"]\n    },\n    \"technical_skills\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"string\"\n      }\n    },\n    \"soft_skills\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"string\"\n      }\n    },\n    \"work_experience\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"job_title\": {\n            \"type\": [\"string\", \"null\"]\n          },\n          \"company\": {\n            \"type\": [\"string\", \"null\"]\n          },\n          \"start_date\": {\n            \"type\": [\"string\", \"null\"]\n          },\n          \"end_date\": {\n            \"type\": [\"string\", \"null\"]\n          },\n          \"currently_working\": {\n            \"type\": [\"boolean\", \"null\"]\n          }\n        }\n      }\n    },\n    \"education\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"degree\": {\n            \"type\": [\"string\", \"null\"]\n          },\n          \"institution\": {\n            \"type\": [\"string\", \"null\"]\n          },\n          \"field_of_study\": {\n            \"type\": [\"string\", \"null\"]\n          }\n        }\n      }\n    },\n    \"projects\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"name\": {\n            \"type\": [\"string\", \"null\"]\n          },\n          \"description\": {\n            \"type\": [\"string\", \"null\"]\n          },\n          \"technologies\": {\n            \"type\": \"array\",\n            \"items\": {\n              \"type\": \"string\"\n            }\n          }\n        }\n      }\n    },\n    \"certifications\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"name\": {\n            \"type\": [\"string\", \"null\"]\n          },\n          \"issuer\": {\n            \"type\": [\"string\", \"null\"]\n          }\n        }\n      }\n    }\n  }\n}",
        "options": {
          "systemPromptTemplate": "You are an expert resume parser.\n\nYour ONLY task is to convert the provided resume into structured JSON.\n\nRules:\n\n1. Return ONLY valid JSON.\n2. Do not include markdown.\n3. Do not explain your reasoning.\n4. Do not infer information that is not explicitly stated.\n5. If a value is missing, return:\n   - null for missing string/number values\n   - [] for missing arrays\n6. Preserve wording where possible.\n7. Do not calculate candidate suitability.\n8. Do not score the candidate.\n9. Do not compare against any job.\n10. Do not hallucinate technologies, companies, projects, certifications, dates or experience.\n11. If confidence is low, return null instead of guessing.\n12. The JSON structure must exactly match the schema above.\n13. Examine/Analyze whole text to get data"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.informationExtractor",
      "typeVersion": 1.2,
      "position": [
        688,
