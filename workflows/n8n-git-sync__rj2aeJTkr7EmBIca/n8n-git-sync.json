    {
      "parameters": {
        "jsCode": "const config = $('Configuration').first().json;\n\nconst github = config.github;\n\nreturn $input.all().map(item => {\n\n  const {\n    updatedAt,\n    versionId,\n    meta,\n    pinData,\n    ...workflow\n  } = item.json;\n\n  // Stable folder name (contains workflow ID)\n  const workflowFolder =\n    workflow.name\n      .replace(/[<>:\"/\\\\|?*]/g, '')\n      .replace(/\\s+/g, '-')\n      .replace(/-+/g, '-') +\n    '__' +\n    workflow.id;\n\n  // Human-readable JSON filename\n  const workflowFile =\n    workflow.name\n      .replace(/[<>:\"/\\\\|?*]/g, '')\n      .trim() +\n    '.json';\n\nreturn {\n  json: {\n    workflow,\n    workflowId: workflow.id,\n    workflowName: workflow.name,\n\n    workflowFolder,\n    workflowFile,\n\n    owner: github.owner,\n    repo: github.repository,\n    branch: github.branch,\n    folder: github.workflowFolder,\n\n    documentation: config.documentation\n  }\n};\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
