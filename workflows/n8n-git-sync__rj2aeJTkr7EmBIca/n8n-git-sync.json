      "id": "e7e2059b-74af-4886-b01a-a5e79d3c6cd3",
      "name": "Get Workflow File from GitHub",
      "webhookId": "921bdb66-d28d-4d38-8f47-ed00b6f1e532",
      "retryOnFail": true,
      "waitBetweenTries": 100,
      "maxTries": 2,
      "credentials": {
        "githubOAuth2Api": {
          "id": "4PJ5LFfzZgNqTF8f",
          "name": "GitHub account"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  // Decode Base64 safely using native Node.js Buffers\n  const decodedText = Buffer.from(item.json.content, 'base64').toString('utf-8');\n  \n  // Parse the decoded text string into a JSON object\n  const githubWorkflow = JSON.parse(decodedText);\n\n  // Remove fields that should not trigger a Git commit\n  delete githubWorkflow.updatedAt;\n  delete githubWorkflow.versionId;\n  delete githubWorkflow.meta;\n  delete githubWorkflow.pinData;\n\n  // Push the cleaned workflow along with its unique GitHub SHA\n  results.push({\n    json: {\n      githubWorkflow,\n      sha: item.json.sha,\n    }\n  });\n}\n\nreturn results;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        -128
      ],
      "id": "7f244a13-d5d5-4d9b-98ca-cd497fbbe8b4",
      "name": "Decode GitHub Content"
    },
    {
      "parameters": {
        "jsCode": "const results = [];\n\nconst currentItems = $('Prepare Workflow').all();\nconst githubItems = $input.all();\n\nfor (let i = 0; i < githubItems.length; i++) {\n\n  const workflow = currentItems[i].json.workflow;\n  const githubWorkflow = githubItems[i].json.githubWorkflow;\n\n  const changed =\n    JSON.stringify(workflow) !== JSON.stringify(githubWorkflow);\n\n  results.push({\n  json: {\n    ...currentItems[i].json,\n    githubWorkflow: githubItems[i].json.githubWorkflow,\n    sha: githubItems[i].json.sha,\n    changed\n  }\n});\n}\n\nreturn results;"
      },
