    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  // Decode Base64 safely using native Node.js Buffers\n  const decodedText = Buffer.from(item.json.content, 'base64').toString('utf-8');\n  \n  // Parse the decoded text string into a JSON object\n  const githubWorkflow = JSON.parse(decodedText);\n\n  // Remove fields that should not trigger a Git commit\n  delete githubWorkflow.updatedAt;\n  delete githubWorkflow.versionId;\n  delete githubWorkflow.meta;\n  delete githubWorkflow.pinData;\n\n  // Push the cleaned workflow along with its unique GitHub SHA\n  results.push({\n    json: {\n      githubWorkflow,\n      sha: item.json.sha,\n    }\n  });\n}\n\nreturn results;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        96
      ],
      "id": "7f244a13-d5d5-4d9b-98ca-cd497fbbe8b4",
      "name": "decode github content from base64"
    },
    {
      "parameters": {
        "jsCode": "const results = [];\n\nconst currentItems = $('transform workflow JSON').all(); // Your cleaned n8n workflows\nconst githubItems = $input.all();                   // Output from Decode\n\nfor (let i = 0; i < currentItems.length; i++) {\n\n  const currentWorkflow = currentItems[i].json.workflow;\n  const githubWorkflow = githubItems[i].json.githubWorkflow;\n\n  const changed =\n    JSON.stringify(currentWorkflow) !== JSON.stringify(githubWorkflow);\n\n  results.push({\n    json: {\n      workflow: currentWorkflow,\n      githubWorkflow,\n      sha: githubItems[i].json.sha,\n      changed\n    }\n  });\n}\n\nreturn results;"
      },
